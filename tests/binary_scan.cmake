if(NOT DEFINED STEALTH_BINARY)
    message(FATAL_ERROR "STEALTH_BINARY is required")
endif()

file(READ "${STEALTH_BINARY}" binary HEX)
string(TOLOWER "${binary}" binary)

set(narrow "535445414c54484c49425f42494e4152595f5343414e5f53454e54494e454c5f4e4152524f575f3946313345324630")
set(wide_utf16le "53005400450041004c00540048004c00490042005f00420049004e004100520059005f005300430041004e005f00530045004e00540049004e0045004c005f0057004900440045005f0039004600310033004500320046003000")
set(wide_utf32le "")

string(FIND "${binary}" "${narrow}" narrow_pos)
string(FIND "${binary}" "${wide_utf16le}" wide_utf16le_pos)
string(FIND "${binary}" "${wide_utf32le}" wide_utf32le_pos)

if(NOT narrow_pos EQUAL -1)
    message(FATAL_ERROR "Plaintext narrow sentinel found in ${STEALTH_BINARY}")
endif()

if(NOT wide_utf16le_pos EQUAL -1)
    message(FATAL_ERROR "Plaintext UTF-16 wide sentinel found in ${STEALTH_BINARY}")
endif()

if(NOT wide_utf32le_pos EQUAL -1)
    message(FATAL_ERROR "Plaintext UTF-32 wide sentinel found in ${STEALTH_BINARY}")
endif()

message(STATUS "No plaintext sentinel strings found in ${STEALTH_BINARY}")
